<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 https://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>open-runtime</id>
    <formats>
        <format>dir</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <baseDirectory>omron-signal-analysis-server-open-runtime</baseDirectory>
    <fileSets>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/bin</directory>
            <outputDirectory>/bin</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/runtime-lib</directory>
            <outputDirectory>/lib</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>/lib</outputDirectory>
            <includes>
                <include>platform-runtime-*.jar</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.parent.basedir}/platform-config/src/main/resources/etc</directory>
            <outputDirectory>/etc</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.parent.basedir}/platform-config/src/main/resources/init</directory>
            <outputDirectory>/init</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/deploy</directory>
            <outputDirectory>/deploy</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/resources</directory>
            <outputDirectory>/resources</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/system</directory>
            <outputDirectory>/system</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.parent.basedir}/platform-webapp/src/main/resources/webapps</directory>
            <outputDirectory>/webapps</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/data</directory>
            <outputDirectory>/data</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/log</directory>
            <outputDirectory>/log</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/resources/storage</directory>
            <outputDirectory>/storage</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
